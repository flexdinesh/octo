{
  "name": "octo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint --no-error-on-unmatched-pattern .",
    "lint:fix": "oxlint --fix --no-error-on-unmatched-pattern ."
  },
  "devDependencies": {
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "turbo": "2.9.18",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=26"
  },
  "packageManager": "pnpm@11.8.0"
}
